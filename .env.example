# BugZero AI Configuration
PORT=3000

# GitLab Credentials
# Get your Personal Access Token (PAT) at https://gitlab.com/-/profile/personal_access_tokens
GITLAB_TOKEN=your_gitlab_personal_access_token_here
GITLAB_WEBHOOK_SECRET=your_gitlab_secret_here

# GitHub Credentials
# Get your PAT at https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your_github_secret_here

# OpenAI Credentials
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
