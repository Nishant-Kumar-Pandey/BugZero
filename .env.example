# ─────────────────────────────────────────────────────────────
#  BugZero AI — Environment Configuration
# ─────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values
#  NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────

# GitHub Personal Access Token
# Scopes required: repo, pull_requests, read:org
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# GitHub Webhook Secret
# Generate with: openssl rand -hex 32
# Set this in your GitHub repo → Settings → Webhooks
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# OpenAI API Key (for AI-powered code fixes)
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# Server port (default: 3000)
PORT=3000

# Added by BugZero AI
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE  # TODO: Rotate this key!
BEARER_TOKEN=Bearer Token  # TODO: Rotate this key!
